# Database (Neon / Supabase / any Postgres connection string)
DATABASE_URL="postgresql://user:password@host:5432/edu_platform?schema=public"

# JWT
JWT_SECRET="change-this-to-a-long-random-string"

# Cloudflare R2 (S3-compatible) - or swap for AWS S3 credentials
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET="edu-platform-files"

# Frontend origin allowed for CORS
FRONTEND_URL="http://localhost:5173"

# Optional email provider for password reset emails (e.g. https://resend.com)
# Leave empty during development - reset links will just be printed to the
# backend console instead of being emailed.
RESEND_API_KEY=""
MAIL_FROM="no-reply@yourdomain.com"

# Optional SMS provider (Twilio) for report-published SMS notifications.
# Leave empty during development - messages will just be printed to the
# backend console instead of being sent.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Optional: enables AI question generation from curriculum text (exam platform).
# Without it, teachers can still use the heuristic generator or add questions manually.
ANTHROPIC_API_KEY=""

PORT=4000
